# Teams bot host runtime configuration (MCP-based architecture)

# Foundry project endpoint used by src/teams/bot.py direct agent invocation
PROJECT_ENDPOINT=https://mslearn-agent-project-2-resource.services.ai.azure.com/api/projects/mslearn-agent-project-2026

# Deployed agent names in Foundry (override only if different)
LEARNING_PATH_AGENT_NAME=LearningPathAgent
SEARCH_AGENT_NAME=MicrosoftLearnSearchAgent
SKILL_GAP_AGENT_NAME=SkillGapAgent

# When Teams user IDs do not match mock SkillGap IDs (user-123, user-456),
# bot.py falls back to this SkillGap mock user.
DEFAULT_SKILL_GAP_USER_ID=user-123

# Bot Framework channel authentication (required for Teams channel)
MicrosoftAppId=your-microsoft-app-id
MicrosoftAppPassword=your-microsoft-app-password

# Host settings for src/teams/app.py
PORT=3978

# Optional voice features
# SPEECH_KEY=your-speech-service-key
# SPEECH_REGION=eastus
